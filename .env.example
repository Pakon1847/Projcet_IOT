# ─── Copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรง ───────────────────────────

# InfluxDB
INFLUX_USERNAME=admin
INFLUX_PASSWORD=your_password_here
INFLUX_ORG=pm25_org
INFLUX_BUCKET=pm25_bucket
INFLUX_TOKEN=your_influx_token_here
INFLUX_URL=http://localhost:8086

# SQLite (backend)
DATABASE_URL=sqlite:////app/data/pm25.db

# JWT Auth
SECRET_KEY=your_super_secret_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 ชั่วโมง

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_SENSOR=pm25/sensor/#
MQTT_TOPIC_FAN=pm25/fan/#

# Notification
LINE_NOTIFY_TOKEN=your_line_notify_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Grafana
GRAFANA_PASSWORD=admin

# Ollama (AI Chat)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# Device
DEVICE_ID=pi4_home_001
DEVICE_NAME=เครื่องฟอกอากาศห้องนอน
